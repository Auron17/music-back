generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id        BigInt   @id @default(autoincrement())
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model Artist {
  id                 BigInt   @id @default(autoincrement())
  name               String   @db.VarChar(255)
  bio                String?
  profileImageUrl    String?  @map("profile_image_url") @db.VarChar(500)
  backgroundImageUrl String?  @map("background_image_url") @db.VarChar(500)
  instagramUrl       String?  @map("instagram_url") @db.VarChar(500)
  telegramUrl        String?  @map("telegram_url") @db.VarChar(500)
  youtubeUrl         String?  @map("youtube_url") @db.VarChar(500)
  createdAt          DateTime @default(now()) @map("created_at")

  albums Album[]
  songs  Song[]
  videos Video[]

  @@map("artists")
}

model Album {
  id            BigInt   @id @default(autoincrement())
  artistId      BigInt?  @map("artist_id")
  title         String   @db.VarChar(255)
  coverImageUrl String?  @map("cover_image_url") @db.VarChar(500)
  releaseYear   Int?     @map("release_year")
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  artist Artist? @relation(fields: [artistId], references: [id], onDelete: SetNull)
  songs  Song[]

  @@index([isActive, createdAt(sort: Desc)])
  @@index([artistId])
  @@map("albums")
}

model Song {
  id              BigInt   @id @default(autoincrement())
  artistId        BigInt?  @map("artist_id")
  albumId         BigInt?  @map("album_id")
  title           String   @db.VarChar(255)
  durationSeconds Int?     @map("duration_seconds")
  audioUrl        String   @map("audio_url") @db.VarChar(500)
  coverImageUrl   String?  @map("cover_image_url") @db.VarChar(500)
  releaseYear     Int?     @map("release_year")
  playCount       BigInt   @default(0) @map("play_count")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  artist Artist?    @relation(fields: [artistId], references: [id], onDelete: SetNull)
  album  Album?     @relation(fields: [albumId], references: [id], onDelete: SetNull)
  likes  SongLike[]

  @@index([isActive, sortOrder, createdAt(sort: Desc)])
  @@index([isActive, playCount(sort: Desc)])
  @@index([albumId, isActive, sortOrder])
  @@index([title])
  @@map("songs")
}

model SongLike {
  id        BigInt   @id @default(autoincrement())
  songId    BigInt   @map("song_id")
  deviceId  String   @map("device_id") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([deviceId, songId])
  @@index([deviceId, createdAt(sort: Desc)])
  @@index([songId])
  @@map("song_likes")
}

model Video {
  id           BigInt   @id @default(autoincrement())
  artistId     BigInt?  @map("artist_id")
  title        String   @db.VarChar(255)
  youtubeUrl   String   @map("youtube_url") @db.VarChar(500)
  youtubeId    String   @map("youtube_id") @db.VarChar(50)
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  viewCount    BigInt   @default(0) @map("view_count")
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  releaseYear  Int?     @map("release_year")
  createdAt    DateTime @default(now()) @map("created_at")

  artist Artist? @relation(fields: [artistId], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder, createdAt(sort: Desc)])
  @@map("videos")
}
