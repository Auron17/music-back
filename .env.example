# Supabase runtime connection.
# Use Supavisor transaction pooler for deployed/serverless apps. It usually uses port 6543.
DATABASE_URL="postgresql://prisma.[PROJECT_REF]:[PRISMA_PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase migration/direct connection.
# Use the Supavisor session pooler or direct database URL. Session pooler usually uses port 5432.
DIRECT_URL="postgresql://prisma.[PROJECT_REF]:[PRISMA_PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="24h"
UPLOAD_DIR="./uploads"
PORT=8080
DEFAULT_ADMIN_USERNAME="admin"
DEFAULT_ADMIN_PASSWORD="admin123"
CORS_ORIGINS="*"
